#include <stdio.h>
#include <time.h>
#include "notification.h"

void afficherHeure() {
    time_t t;
    struct tm *tm_info;

    time(&t);
    tm_info = localtime(&t);

    printf("[%02d:%02d:%02d] ",
           tm_info->tm_hour,
           tm_info->tm_min,
           tm_info->tm_sec);
}

void notificationSucces(const char *message) {
    if (message == NULL) return;
    afficherHeure();
    printf("[SUCCES] %s\n", message);
}

void notificationErreur(const char *message) {
